{
  "name": "tab-yeet",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Firefox extension: copy tab URLs with transforms and formatting",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:ext": "web-ext lint --source-dir .",
    "build:ext": "web-ext build --source-dir . --artifacts-dir web-ext-artifacts",
    "ci": "npm test && npm run lint:ext && npm run build:ext"
  },
  "devDependencies": {
    "jsdom": "^26.0.0",
    "vitest": "^4.1.2",
    "web-ext": "^10.1.0"
  }
}
