{
  "manifest_version": 2,
  "name": "Tab Yeet",
  "version": "0.2.1",
  "description": "Copy tab URLs from the current window with optional URL transforms and formatting.",
  "permissions": [
    "tabs",
    "clipboardWrite",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "applications": {
    "gecko": {
      "id": "tab-yeet@webextension.cani.ne.jp",
      "strict_min_version": "109.0"
    }
  }
}
