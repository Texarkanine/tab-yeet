{
  "manifest_version": 2,
  "name": "Tab Yeet",
  "version": "0.8.0",
  "description": "Copy tab URLs from the current window with optional URL transforms and formatting.",
  "permissions": [
    "tabs",
    "clipboardWrite",
    "storage"
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "32": "icons/icon-32.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "32": "icons/icon-32.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-yeet@webextension.cani.ne.jp",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
